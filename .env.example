# ─── Database (Neon) ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# ─── Neon Auth (authentication) ───────────────────────────────────────────
# PUBLIC base URL of your Neon Auth endpoint (ends in /neondb/auth). The
# browser bundle reads this to start login, so it MUST be VITE_-prefixed. The
# client build also accepts a server-style NEON_AUTH_URL alias.
VITE_NEON_AUTH_URL=https://ep-young-star-ae2aja7j.neonauth.c-2.us-east-2.aws.neon.tech/neondb/auth
# JWKS endpoint the API uses to verify Neon Auth session JWTs. If omitted, it is
# derived from VITE_NEON_AUTH_URL/NEON_AUTH_URL as `<auth-url>/.well-known/jwks.json`.
NEON_AUTH_JWKS_URL=https://ep-young-star-ae2aja7j.neonauth.c-2.us-east-2.aws.neon.tech/neondb/auth/.well-known/jwks.json

# ─── Auth0 (LEGACY — optional) ────────────────────────────────────────────
# Auth0 is no longer used for request authentication (replaced by Neon Auth).
# These remain ONLY for the optional Management API used to provision reader/
# admin accounts. Leave blank unless you use that admin-provisioning feature.
# AUTH0_MGMT_CLIENT_ID=
# AUTH0_MGMT_CLIENT_SECRET=
# Production frontend URL. If CORS_ORIGIN is unset/localhost, this is used.
# AUTH0_ALLOWED_URL=https://soulseerpsychics.vercel.app

# ─── Agora (real-time voice/video) ───────────────────────────────────────
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# ─── Stripe ──────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# ─── Cloudinary (profile image uploads) ──────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Brevo (transactional email) ─────────────────────────────────────────
BREVO_API_KEY=
# F-027: defaults are baked into config.ts; override here only if you need
# to rebrand the sender. BREVO_SENDER_EMAIL default: hello@soulseerpsychics.com
# BREVO_SENDER_NAME default: SoulSeer
# NEWSLETTER_WELCOME_ENABLED default: true (set to "false" to disable welcome email)

# ─── Frontend URL (used in transactional email links) ────────────────────
# F-027: the SPA's public origin. Used for the "Browse Readers" CTA and
# unsubscribe links in Brevo templates. Default: https://soulseerpsychics.vercel.app
# FRONTEND_URL=https://soulseerpsychics.vercel.app

# ─── PostHog (product analytics) ─────────────────────────────────────────
# F-027: defaults to https://us.i.posthog.com. POSTHOG_API_KEY is empty by
# default so the SDK starts up disabled until configured.
# POSTHOG_API_KEY=
# POSTHOG_HOST=https://us.i.posthog.com

# ─── Pendo (server-side track) ───────────────────────────────────────────
# F-009: the integration key for Pendo's data/track endpoint. Empty by
# default; when unset, pendoTrack() is a no-op. Pendo frontend key lives in
# client/index.html (public CDN script).
# PENDO_INTEGRATION_KEY=

# ─── Admin ───────────────────────────────────────────────────────────────
# F-027: comma-separated list of emails that are promoted to role=admin on
# their next /api/auth/sync. Default: emilynnj14@gmail.com
# ADMIN_EMAILS=emilynnj14@gmail.com
# Comma-separated emails bootstrapped to role=reader on next /api/auth/sync.
# Default: emilynn992@gmail.com
# READER_EMAILS=emilynn992@gmail.com

# ─── Server ──────────────────────────────────────────────────────────────
PORT=5000
CORS_ORIGIN=http://localhost:5173
NODE_ENV=production
