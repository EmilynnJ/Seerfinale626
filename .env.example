# ─── Database (Supabase Postgres — the SOLE database) ─────────────────────
# Use the Supabase connection string (Project Settings → Database). The
# session pooler string is recommended for serverless deployments.
# Aliases accepted: SUPABASE_DB_URL, POSTGRES_URL, POSTGRES_PRISMA_URL
DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ─── Supabase (auth + admin API) ──────────────────────────────────────────
# Project URL and keys: Supabase dashboard → Project Settings → API.
SUPABASE_URL=https://your-project.supabase.co
# Public anon/publishable key (safe for the browser; also used by the client
# build as VITE_SUPABASE_ANON_KEY / VITE_SUPABASE_PUBLISHABLE_KEY).
SUPABASE_ANON_KEY=your-anon-key
# Service-role key — SERVER ONLY. Used for the Auth admin API (reader account
# provisioning). Never expose to the client, never prefix with VITE_.
# Alias accepted: SUPABASE_SECRET_KEY (sb_secret_...)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# JWT verification: set the legacy HS256 JWT secret (Project Settings → API →
# JWT Settings) for local verification, OR leave it empty to verify against
# the project's JWKS endpoint (asymmetric keys).
SUPABASE_JWT_SECRET=
# Optional explicit JWKS URL (defaults to ${SUPABASE_URL}/auth/v1/.well-known/jwks.json)
# SUPABASE_JWKS_URL=

# ─── Cloudflare Realtime (SFU + TURN + MoQ) — ALL real-time comms ─────────
# Replaces Agora entirely. App credentials are SERVER ONLY; clients receive
# short-lived, server-issued session access.
CLOUDFLARE_REALTIME_APP_ID=your-realtime-app-id
CLOUDFLARE_REALTIME_TOKEN=your-realtime-app-token
# Cloudflare Calls TURN service (NAT traversal) — generates short-lived ICE
# credentials per session.
CLOUDFLARE_TURN_KEY_ID=your-turn-key-id
CLOUDFLARE_TURN_API_TOKEN=your-turn-api-token
# MoQ (Media over QUIC) relay for chat-type real-time data transport.
# CLOUDFLARE_MOQ_RELAY_URL=https://relay.cloudflare.mediaoverquic.com
# API base override (default: https://rtc.live.cloudflare.com/v1)
# CLOUDFLARE_REALTIME_BASE_URL=

# ─── Stripe ──────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# ─── Cloudinary (profile image uploads) ──────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Brevo (transactional email) ─────────────────────────────────────────
BREVO_API_KEY=
# F-027: defaults are baked into config.ts; override here only if you need
# to rebrand the sender. BREVO_SENDER_EMAIL default: hello@soulseerpsychics.com
# BREVO_SENDER_NAME default: SoulSeer
# NEWSLETTER_WELCOME_ENABLED default: true (set to "false" to disable welcome email)

# ─── Frontend URL (used in transactional email links) ────────────────────
# F-027: the SPA's public origin. Used for the "Browse Readers" CTA and
# unsubscribe links in Brevo templates. Default: https://soulseerpsychics.vercel.app
# FRONTEND_URL=https://soulseerpsychics.vercel.app

# ─── PostHog (product analytics) ─────────────────────────────────────────
# F-027: defaults to https://us.i.posthog.com. POSTHOG_API_KEY is empty by
# default so the SDK starts up disabled until configured.
# POSTHOG_API_KEY=
# POSTHOG_HOST=https://us.i.posthog.com

# ─── Pendo (server-side track) ───────────────────────────────────────────
# F-009: the integration key for Pendo's data/track endpoint. Empty by
# default; when unset, pendoTrack() is a no-op. Pendo frontend key lives in
# client/index.html (public CDN script).
# PENDO_INTEGRATION_KEY=

# ─── Admin ───────────────────────────────────────────────────────────────
# F-027: comma-separated list of emails that are promoted to role=admin on
# their next /api/auth/sync. Default: emilynnj14@gmail.com
# ADMIN_EMAILS=emilynnj14@gmail.com

# ─── Server ──────────────────────────────────────────────────────────────
PORT=5000
CORS_ORIGIN=http://localhost:5173
NODE_ENV=production
