{
  "name": "soulseer",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10"
  },
  "workspaces": [
    "shared",
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n client,server -c magenta,cyan \"npm run dev -w client\" \"npm run dev -w server\"",
    "dev:client": "npm run dev -w client",
    "dev:server": "npm run dev -w server",
    "build": "npm run build -w shared && npm run build -w server && npm run build -w client",
    "build:shared": "npm run build -w shared",
    "typecheck": "npm run typecheck -w shared && npm run typecheck -w server && npm run typecheck -w client",
    "test": "npm run test -w client && npm run test -w server",
    "test:client": "npm run test -w client",
    "test:server": "npm run test -w server",
    "lint": "npm run lint -w client && npm run lint -w server",
    "lint:fix": "npm run lint:fix -w client && npm run lint:fix -w server",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.4",
    "ai": "^6.0.205",
    "cloudinary": "^2.5.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.45.2",
    "express": "^4.22.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "jose": "^5.9.6",
    "multer": "^2.2.0",
    "pg": "^8.13.1",
    "pino": "^9.9.0",
    "pino-http": "^10.0.0",
    "serverless-http": "^4.0.0",
    "stripe": "^17.2.0",
    "vibecheck": "^0.0.1-0",
    "ws": "^8.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@netlify/functions": "^2.8.0",
    "@types/cors": "^2.8.18",
    "@types/express": "^4.17.25",
    "@types/multer": "^1.4.12",
    "@types/pg": "^8.11.10",
    "@types/ws": "^8.5.14",
    "@vercel/node": "^5.1.0",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.9",
    "typescript": "^5.7.3"
  }
}
