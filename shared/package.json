  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
