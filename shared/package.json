{
  "name": "@soulseer/shared",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
