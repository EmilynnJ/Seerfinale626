# ═══════════════════════════════════════════════════════════════════════════
# CLIENT ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════════════════════
#
# SECURITY NOTICE:
# All client-side environment variables MUST be prefixed with "VITE_"
# 
# The Vite build configuration restricts loadEnv() to only load variables
# with the VITE_ prefix. This prevents sensitive server-side secrets (like
# database credentials, API keys, CI/CD tokens) from being embedded in the
# client-side JavaScript bundle where they would be publicly accessible.
#
# ✅ SAFE:   VITE_API_URL, VITE_AUTH0_DOMAIN (embedded in client bundle)
# ❌ UNSAFE: DATABASE_URL, SECRET_KEY (would be exposed without prefix filter)
#
# See: client/src/test/vite-config.test.ts for security validation tests
# ═══════════════════════════════════════════════════════════════════════════

# ─── Auth0 ────────────────────────────────────────────────────────────────
VITE_AUTH0_DOMAIN=dev-2x1dti3irhuz62jc.us.auth0.com
VITE_AUTH0_CLIENT_ID=****OwkD
# Audience MUST be exactly https://soulseerpsychics.vercel.app (no api. prefix) per env.pdf.
VITE_AUTH0_AUDIENCE=https://soulseerpsychics.vercel.app
# Production redirect URI per env.pdf — must match the deployed Vercel origin.
VITE_AUTH0_REDIRECT_URI=https://soulseerpsychics.vercel.app
# Local dev override (uncomment when running `npm run dev`):
# VITE_AUTH0_REDIRECT_URI=http://localhost:5173

# ─── API ─────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:5000
VITE_WS_URL=ws://localhost:5000

# ─── Agora (client-side App ID only) ────────────────────────────────────
VITE_AGORA_APP_ID=your-agora-app-id

# ─── Stripe (publishable key only) ──────────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
